# Apache configuration to hide .html extension from URL bar
# This only works on your live website server (Apache), not when opening files locally.

RewriteEngine On

# 1. Externally redirect /example.html to /example (removes the extension)
RewriteCond %{THE_REQUEST} ^[A-Z]{3,9}\ /([^.]+)\.html\ HTTP
RewriteRule ^([^.]+)\.html$ /$1 [R=301,L]

# 2. Internally rewrite /example to /example.html (serves the file)
RewriteCond %{REQUEST_FILENAME} !-d
RewriteCond %{REQUEST_FILENAME}\.html -f
RewriteRule ^([^/]+)$ $1.html [L]
